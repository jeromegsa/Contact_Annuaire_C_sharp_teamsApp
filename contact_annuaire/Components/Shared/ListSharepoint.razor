@page "/liste-sharepoint"
@using contact_annuaire.Models
@using contact_annuaire.Services
@using contact_annuaire.Components.Shared
@inject SharePointService SharePointService
@inject TeamsUserCredential teamsUserCredential

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-8">

    @* ===== HEADER ===== *@
    <div class="max-w-6xl mx-auto mb-8">
        <div class="bg-white rounded-2xl shadow-lg p-8 flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-extrabold text-indigo-700 mb-1">📋 Liste SharePoint</h1>
                <p class="text-gray-400 text-sm">Données depuis iokeo.sharepoint.com</p>
            </div>
            <div class="bg-indigo-50 rounded-xl px-6 py-4 text-center">
                <p class="text-4xl font-extrabold text-indigo-600">@contacts.Count</p>
                <p class="text-gray-400 text-xs">contact(s)</p>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto">

        @* ===== ERREUR ===== *@
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-600 rounded-xl p-4 mb-6">
                ⚠️ @errorMessage
            </div>
        }

        @* ===== CONSENTEMENT ===== *@
        @if (needConsent)
        {
            <div class="bg-white rounded-2xl shadow p-8 text-center mb-6">
                <p class="text-5xl mb-4">🔐</p>
                <p class="text-gray-700 font-semibold text-lg mb-2">Autorisation requise</p>
                <p class="text-gray-400 text-sm mb-6">
                    Autorisez l'accès à SharePoint pour afficher et gérer les contacts.
                </p>
                <button class="px-8 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 transition-colors duration-200"
                        @onclick="ConsentAndLoad">
                    Autoriser l'accès
                </button>
            </div>
        }
        else
        {
            @* ===== FORMULAIRE ===== *@
            <FormulaireContact ContactAModifier="contactAModifier"
                               OnAjouter="AjouterContact"
                               OnModifier="ModifierContact"
                               OnAnnuler="AnnulerModification" />

            @* ===== BARRE DE RECHERCHE ===== *@
            <FilterContact OnTapWord="TrieContact" />

            @* ===== CHARGEMENT ===== *@
            @if (isLoading)
            {
                <div class="flex justify-center mt-12">
                    <FluentProgressRing />
                </div>
            }
            else if (!contactsFiltres.Any())
            {
                <div class="bg-white rounded-2xl shadow p-12 text-center mt-6">
                    <p class="text-6xl mb-4">🔍</p>
                    <p class="text-gray-400 text-lg font-medium">Aucun contact trouvé</p>
                </div>
            }
            else
            {
                @* ===== GRILLE ===== *@
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
                    @foreach (var contact in contactsFiltres)
                    {
                        <CarteContact Contact="contact"
                                      OnSupprimer="SupprimerContact"
                                      OnModifier="SelectionnerContact" />
                    }
                </div>
            }
        }

    </div>

</div>

@code {
    private List<Contact> contacts = new();
    private List<Contact> contactsFiltres = new();
    private Contact contactAModifier = null;
    private bool isLoading = true;
    private bool needConsent = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await ChargerContacts();
    }

    private async Task ChargerContacts()
    {
        try
        {
            isLoading = true;
            errorMessage = "";
            contacts = await SharePointService.GetContactsAsync();
            contactsFiltres = contacts;
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("AADSTS65001"))
                needConsent = true;
            else
                errorMessage = $"Erreur lors du chargement : {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ConsentAndLoad()
    {
        try
        {
            await SharePointService.DemanderConsentementAsync();
            needConsent = false;
            await ChargerContacts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du consentement : {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task AjouterContact(Contact contact)
    {
        try
        {
            await SharePointService.AjouterContactAsync(contact);
            await ChargerContacts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout : {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ModifierContact(Contact contact)
    {
        try
        {
            await SharePointService.ModifierContactAsync(contact);
            contactAModifier = null;
            await ChargerContacts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la modification : {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task SupprimerContact(int id)
    {
        try
        {
            await SharePointService.SupprimerContactAsync(id.ToString());
            await ChargerContacts();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la suppression : {ex.Message}";
            StateHasChanged();
        }
    }

    private void SelectionnerContact(int id)
    {
        contactAModifier = contacts.FirstOrDefault(c => c.Id == id);
        StateHasChanged();
    }

    private void AnnulerModification()
    {
        contactAModifier = null;
        StateHasChanged();
    }

    private void TrieContact(string word)
    {
        if (string.IsNullOrEmpty(word))
            contactsFiltres = contacts;
        else
            contactsFiltres = contacts
                .Where(c => c.Prenom.ToLower().Contains(word.ToLower())
                         || c.Nom.ToLower().Contains(word.ToLower()))
                .ToList();
        StateHasChanged();
    }

}