<div class="mb-6">
    <h3 class="text-gray-600 font-semibold text-sm mb-2"> Rechercher</h3>
    <input type="search"
           placeholder="Tape pour rechercher..."
           class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all duration-200"
           @oninput="e => OnTapWord.InvokeAsync(e.Value.ToString())" />
</div>

@code {
    [Parameter]
    public EventCallback<string> OnTapWord { get; set; }
}