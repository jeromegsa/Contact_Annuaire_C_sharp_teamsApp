@using contact_annuaire.Models

<div class="bg-white rounded-xl p-6 shadow-md border border-gray-100 mb-6">

    <h3 class="text-gray-800 font-semibold text-base mb-4">
        @(ContactAModifier != null ? "✏️ Modifier le contact" : "➕ Ajouter un contact")
    </h3>

    <div class="flex flex-wrap gap-3 items-end">

        <input placeholder="Prénom"
               class="flex-1 min-w-36 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all duration-200"
               @bind="nouveauContact.Prenom" />

        <input placeholder="Nom"
               class="flex-1 min-w-36 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all duration-200"
               @bind="nouveauContact.Nom" />

        <input placeholder="Email"
               class="flex-1 min-w-36 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all duration-200"
               @bind="nouveauContact.Email" />

        <input placeholder="Téléphone"
               class="flex-1 min-w-36 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all duration-200"
               @bind="nouveauContact.Telephone" />

        <button class="px-6 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 transition-colors duration-200 whitespace-nowrap"
                @onclick="Soumettre">
            @(ContactAModifier != null ? "✅ Valider" : "Ajouter")
        </button>

        @* Bouton Annuler visible uniquement en mode modification *@
        @if (ContactAModifier != null)
        {
            <button class="px-6 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-semibold hover:bg-gray-200 transition-colors duration-200 whitespace-nowrap"
                    @onclick="Annuler">
                ❌ Annuler
            </button>
        }

    </div>

</div>

@code {
    private Contact nouveauContact = new Contact();

    [Parameter]
    public Contact ContactAModifier { get; set; }

    [Parameter]
    public EventCallback<Contact> OnAjouter { get; set; }

    [Parameter]
    public EventCallback<Contact> OnModifier { get; set; }

    [Parameter]
    public EventCallback OnAnnuler { get; set; }

    // Quand ContactAModifier change, on remplit le formulaire
    protected override void OnParametersSet()
    {
        if (ContactAModifier != null)
        {
            nouveauContact = new Contact
            {
                Id = ContactAModifier.Id,
                Prenom = ContactAModifier.Prenom,
                Nom = ContactAModifier.Nom,
                Email = ContactAModifier.Email,
                Telephone = ContactAModifier.Telephone
            };
        }
        else
        {
            nouveauContact = new Contact();
        }
    }

    private async Task Soumettre()
    {
        if (!string.IsNullOrEmpty(nouveauContact.Prenom) && !string.IsNullOrEmpty(nouveauContact.Nom))
        {
            if (ContactAModifier != null)
                await OnModifier.InvokeAsync(nouveauContact);
            else
                await OnAjouter.InvokeAsync(nouveauContact);

            nouveauContact = new Contact();
        }
    }

    private async Task Annuler()
    {
        nouveauContact = new Contact();
        await OnAnnuler.InvokeAsync();
    }
}