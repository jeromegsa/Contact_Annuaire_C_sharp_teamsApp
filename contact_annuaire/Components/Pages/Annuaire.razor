@page "/annuaire"
@using contact_annuaire.Models
@using contact_annuaire.Services
@using contact_annuaire.Components.Shared
@inject ContactService ContactService

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-8">

    @* ===== HEADER ===== *@
    <div class="max-w-6xl mx-auto mb-8">
        <div class="bg-white rounded-2xl shadow-lg p-8 flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-extrabold text-indigo-600 mb-1">📒 Mon Annuaire</h1>
                <p class="text-gray-400 text-sm">Gérez vos contacts facilement</p>
            </div>
            <div class="bg-indigo-50 rounded-xl px-6 py-4 text-center">
                <p class="text-4xl font-extrabold text-indigo-600">@contacts.Count</p>
                <p class="text-gray-400 text-xs">contact(s)</p>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto">

        @* ===== FORMULAIRE (ajout ou modification) ===== *@
        <FormulaireContact ContactAModifier="contactAModifier"
                           OnAjouter="AjouterContact"
                           OnModifier="ModifierContact"
                           OnAnnuler="AnnulerModification" />

        @* ===== BARRE DE RECHERCHE ===== *@
        <FilterContact OnTapWord="TrieContact" />

        @* ===== LISTE VIDE ===== *@
        @if (!contacts.Any())
        {
            <div class="bg-white rounded-2xl shadow p-12 text-center mt-6">
                <p class="text-6xl mb-4">🔍</p>
                <p class="text-gray-400 text-lg font-medium">Aucun contact trouvé</p>
                <p class="text-gray-300 text-sm">Essayez un autre mot clé ou ajoutez un contact</p>
            </div>
        }
        else
        {
            @* ===== GRILLE DES CONTACTS ===== *@
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
                @foreach (var contact in contacts)
                {
                    <CarteContact Contact="contact"
                                  OnSupprimer="SupprimerContact"
                                  OnModifier="SelectionnerContact" />
                }
            </div>
        }

    </div>

  @*   En bas de la page dans Annuaire.razor par exemple
    <div class="max-w-4xl mx-auto mt-8">
        <span class="text-gray-500 text-sm mb-2 block">📋 Formulaire de contact (Microsoft Forms intégré)</span>
        <iframe width="100%"
                height="480px"
                src="https://forms.office.com/Pages/ResponsePage.aspx?id=u9AxRJd-xkqFMeJyfBb7yGUw9R0EooFCt-N4JL2AJ5JUMkg4M1hZTFJJSkNYWVRITkFRSDFJWktaTi4u&embed=true"
                frameborder="0"
                style="border: none;">
        </iframe>
    </div> *@

</div>

@code {
    private List<Contact> contacts = new();
    private List<Contact> tousLesContacts = new();
    private Contact contactAModifier = null;

    protected override void OnInitialized()
    {
        tousLesContacts = ContactService.GetContacts();
        contacts = tousLesContacts;
    }

    private void AjouterContact(Contact contact)
    {
        ContactService.AjouterContact(contact);
        tousLesContacts = ContactService.GetContacts();
        contacts = tousLesContacts;
        StateHasChanged();
    }

    private void SupprimerContact(int id)
    {
        ContactService.SupprimerContact(id);
        tousLesContacts = ContactService.GetContacts();
        contacts = tousLesContacts;
        StateHasChanged();
    }

    // Appelée depuis CarteContact → met le contact en mode modification
    private void SelectionnerContact(int id)
    {
        contactAModifier = tousLesContacts.FirstOrDefault(c => c.Id == id);
        StateHasChanged();
    }

    // Appelée depuis FormulaireContact → valide la modification
    private void ModifierContact(Contact contact)
    {
        ContactService.ModifierContact(contact);
        tousLesContacts = ContactService.GetContacts();
        contacts = tousLesContacts;
        contactAModifier = null;
        StateHasChanged();
    }

    // Appelée depuis FormulaireContact → annule la modification
    private void AnnulerModification()
    {
        contactAModifier = null;
        StateHasChanged();
    }

    private void TrieContact(string word)
    {
        if (string.IsNullOrEmpty(word))
            contacts = tousLesContacts;
        else
            contacts = tousLesContacts
                .Where(c => c.Prenom.ToLower().Contains(word.ToLower())
                         || c.Nom.ToLower().Contains(word.ToLower()))
                .ToList();
        StateHasChanged();
    }
}